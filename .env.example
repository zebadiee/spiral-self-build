
# SLSA Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# MCP Server Configuration
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
LOG_LEVEL=info
PYTHONPATH=/app

# =============================================================================
# Learning System Configuration
# =============================================================================
# Maximum content length for processing (in characters)
MAX_CONTENT_LENGTH=50000

# Insight generation settings
MIN_INSIGHTS=1
MAX_INSIGHTS=5
DEFAULT_CONFIDENCE_THRESHOLD=0.5

# Learning session storage
ENABLE_PERSISTENT_STORAGE=true
DATA_DIRECTORY=./data
LOGS_DIRECTORY=./logs

# =============================================================================
# Dashboard Configuration
# =============================================================================
DASHBOARD_UPDATE_INTERVAL=5
DASHBOARD_PORT=3000
ENABLE_DASHBOARD_AUTH=false

# =============================================================================
# n8n Workflow Automation
# =============================================================================
N8N_HOST=localhost
N8N_PORT=5678
N8N_USER=admin
N8N_PASSWORD=change_this_password
N8N_BASIC_AUTH_ACTIVE=true

# Webhook configuration
WEBHOOK_URL=http://localhost:5678/
N8N_PROTOCOL=http

# File monitoring
WATCH_FOLDER=./watch_folder
ENABLE_FILE_MONITORING=true

# =============================================================================
# Database Configuration (Optional)
# =============================================================================
# Uncomment and configure if using external database
# DATABASE_URL=postgresql://user:password@localhost:5432/slsa_db
# DATABASE_TYPE=postgresql
# DATABASE_POOL_SIZE=10

# Redis configuration (for caching and sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
ENABLE_REDIS_CACHE=true

# =============================================================================
# Security Configuration
# =============================================================================
# API Security
ENABLE_CORS=true
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5678"]
API_KEY_REQUIRED=false
# API_KEY=your_secret_api_key_here

# Rate limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# External Services (Optional)
# =============================================================================
# OpenAI API (for enhanced insight generation)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-3.5-turbo

# Hugging Face (for local ML models)
# HUGGINGFACE_API_KEY=your_huggingface_key_here
# HUGGINGFACE_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# Monitoring and Observability
# =============================================================================
# Logging configuration
LOG_FORMAT=json
LOG_FILE=./logs/slsa.log
ENABLE_FILE_LOGGING=true
ENABLE_CONSOLE_LOGGING=true

# Metrics and monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
PROMETHEUS_ENABLED=false

# Health check configuration
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# =============================================================================
# Development Settings
# =============================================================================
# Development mode settings
DEBUG_MODE=false
RELOAD_ON_CHANGE=false
ENABLE_API_DOCS=true

# Testing configuration
TEST_MODE=false
MOCK_EXTERNAL_SERVICES=false

# =============================================================================
# Production Settings
# =============================================================================
# Production deployment settings
ENVIRONMENT=development
WORKERS=1
WORKER_CLASS=uvicorn.workers.UvicornWorker

# SSL/TLS configuration (for production)
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem
# ENABLE_HTTPS=false

# Backup configuration
# BACKUP_ENABLED=false
# BACKUP_SCHEDULE=0 2 * * *
# BACKUP_RETENTION_DAYS=30
# BACKUP_STORAGE_PATH=./backups

# =============================================================================
# Feature Flags
# =============================================================================
# Enable/disable specific features
ENABLE_PDF_PROCESSING=true
ENABLE_TEXT_PROCESSING=true
ENABLE_BATCH_PROCESSING=true
ENABLE_WORKFLOW_AUTOMATION=true
ENABLE_REAL_TIME_UPDATES=true

# Experimental features
ENABLE_ADVANCED_INSIGHTS=false
ENABLE_MULTI_LANGUAGE_SUPPORT=false
ENABLE_CUSTOM_MODELS=false

# =============================================================================
# Resource Limits
# =============================================================================
# Memory and processing limits
MAX_MEMORY_USAGE=512MB
MAX_CPU_USAGE=80
MAX_CONCURRENT_REQUESTS=50
REQUEST_TIMEOUT=300

# File processing limits
MAX_FILE_SIZE=10MB
MAX_FILES_PER_BATCH=10
PROCESSING_TIMEOUT=120

# =============================================================================
# Custom Configuration
# =============================================================================
# Add your custom environment variables here
# CUSTOM_SETTING_1=value1
# CUSTOM_SETTING_2=value2

# Domain-specific settings
# DOMAIN_NAME=your_domain_here
# ORGANIZATION_NAME=Your Organization
# CONTACT_EMAIL=admin@yourdomain.com

# =============================================================================
# Notes for Production Deployment
# =============================================================================
# 1. Change all default passwords and API keys
# 2. Set ENVIRONMENT=production
# 3. Enable SSL/TLS for secure communication
# 4. Configure proper logging and monitoring
# 5. Set up backup strategies
# 6. Review and adjust resource limits
# 7. Enable security features (rate limiting, API keys)
# 8. Configure external services as needed
# 9. Test all configurations before deployment
# 10. Keep this file secure and never commit to version control
